#!/usr/bin/env bash
set -euo pipefail

# ====== CONFIGURE THESE FOR YOUR ENV ======
API_CONTAINER="mummy_api"          # TaskyHub API container name
DB_CONTAINER="mummy_postgres"      # Postgres container name
DB_NAME="th_db_mummy"              # TaskyHub main DB name
DB_USER="postgres"                 # DB user with privileges to update users
ADMIN_EMAIL="admin@taskyhub.local" # Admin login email in TaskyHub

USERS_TABLE="users"                # Users table name
EMAIL_COLUMN="email"               # Email column
PASSWORD_COLUMN="password_hash"    # Password-hash column
# ==========================================

echo "=== TaskyHub admin password reset ==="
echo "Admin email: ${ADMIN_EMAIL}"
read -s -p "Enter NEW admin password: " NEW_PASS
echo
read -s -p "Confirm NEW admin password: " NEW_PASS_CONFIRM
echo

if [[ "$NEW_PASS" != "$NEW_PASS_CONFIRM" ]]; then
  echo "ERROR: Passwords do not match."
  exit 1
fi

if [[ -z "$NEW_PASS" ]]; then
  echo "ERROR: Password cannot be empty."
  exit 1
fi

echo "1) Generating bcrypt hash inside API container (${API_CONTAINER})..."

HASH=$(
  docker exec -i "${API_CONTAINER}" node - <<EOF
    const bcrypt = require('bcryptjs');
    const password = process.argv[2];
    const saltRounds = 10;
    bcrypt.hash(password, saltRounds).then(hash => {
      console.log(hash);
    }).catch(err => {
      console.error('Error generating hash:', err);
      process.exit(1);
    });
EOF
    "$NEW_PASS"
)

if [[ -z "$HASH" ]]; then
  echo "ERROR: Failed to generate bcrypt hash."
  exit 1
fi

echo "Generated hash: ${HASH}"

echo "2) Updating admin password in Postgres (${DB_CONTAINER})..."

docker exec -i "${DB_CONTAINER}" psql -U "${DB_USER}" -d "${DB_NAME}" <<EOF
UPDATE ${USERS_TABLE}
SET ${PASSWORD_COLUMN} = '${HASH}'
WHERE ${EMAIL_COLUMN} = '${ADMIN_EMAIL}';
EOF

echo "3) Done."
echo "You should now be able to log in to TaskyHub as:"
echo "  Email:    ${ADMIN_EMAIL}"
echo "  Password: (the new password you just set)"