# templates/docker-compose.yml.j2
# Docker Compose configuration for the TaskyHub stack.
# Managed by Ansible and deployed to the /opt/taskyhub directory.
#
# Data Sources:
# - customer_name: Used for container naming and network isolation.
# - postgres_db_name/user: Application database credentials.
# - ui_port/api_port: Host ports for port forwarding.
# - api_base_url/ui_base_url: Domains and URLs for service-to-service communication.

version: "3.9"

services:
  postgres:
    image: postgres:15
    container_name: "{{ customer_name }}_postgres"
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: "{{ tasky_db_super_password | default(postgres_password | default('')) }}"
      POSTGRES_INITDB_ARGS: "--auth-host=scram-sha-256 --auth-local=scram-sha-256"
    volumes:
      - pg_data:/var/lib/postgresql/data
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    networks:
      - taskyhub_net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d postgres -h 127.0.0.1 || exit 1"]
      interval: 5s
      timeout: 5s
      retries: 20
      start_period: 20s

  ae:
    image: docker.n8n.io/n8nio/n8n
    container_name: "{{ customer_name }}_ae"
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: "{{ ae_db_name }}"
      DB_POSTGRESDB_USER: "{{ ae_db_user }}"
      DB_POSTGRESDB_PASSWORD: "{{ tasky_db_ae_password | default(ae_db_password | default('')) }}"
      N8N_HOST: "{{ ui_domain }}"
      N8N_PORT: 5678
      N8N_PROTOCOL: https
      N8N_PATH: "/ae/"
      N8N_PATH_PREFIX: "/ae/"
      N8N_EDITOR_BASE_URL: "https://{{ ui_domain }}/ae/"
      WEBHOOK_URL: "https://{{ ui_domain }}/ae/"
{% if (tasky_n8n_owner_email | default('')) and (tasky_n8n_owner_password | default('')) %}
      N8N_OWNER_EMAIL: "{{ tasky_n8n_owner_email }}"
      N8N_OWNER_PASSWORD: "{{ tasky_n8n_owner_password }}"
      N8N_OWNER_FIRST_NAME: "{{ tasky_n8n_owner_first_name | default('Tasky') }}"
      N8N_OWNER_LAST_NAME: "{{ tasky_n8n_owner_last_name | default('Admin') }}"
{% endif %}
      N8N_BASIC_AUTH_ACTIVE: "{{ 'true' if (tasky_n8n_basic_auth_password | default('')) else 'false' }}"
      N8N_BASIC_AUTH_USER: "{{ tasky_n8n_basic_auth_user | default('taskyhub') }}"
      N8N_BASIC_AUTH_PASSWORD: "{{ tasky_n8n_basic_auth_password | default('') }}"
      N8N_PROXY_HOPS: 1
      N8N_SECURE_COOKIE: "true"
      N8N_LOG_LEVEL: info
      N8N_LOG_OUTPUT: file
      N8N_LOG_FILE_LOCATION: /home/node/logs/n8n.log
      N8N_LOG_FILE_SIZE_MAX: 16
      N8N_LOG_FILE_COUNT_MAX: 100
    volumes:
      - ae_data:/home/node/.n8n
      - /opt/{{ customer_name }}/ae-logs:/home/node/logs
    networks:
      - taskyhub_net
    ports:
      - "127.0.0.1:{{ ae_host_port }}:5678"
    healthcheck:
      test:
        [
          "CMD-SHELL",
          "node -e \"const net=require('net');const s=net.connect(5678,'127.0.0.1');s.on('connect',()=>process.exit(0));s.on('error',()=>process.exit(1));\"",
        ]
      interval: 10s
      timeout: 5s
      retries: 5

  grafana:
    image: grafana/grafana:latest
    container_name: "{{ customer_name }}_grafana"
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      GF_SECURITY_ADMIN_USER: "{{ tasky_grafana_admin_user | default(grafana_admin_user | default('admin')) }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ tasky_grafana_admin_password | default(grafana_admin_password | default('')) }}"

      # Branding
      GF_BRANDING_APP_TITLE: TaskyHub
      GF_BRANDING_LOGIN_TITLE: TaskyHub Login

      # Security - Allow embedding
      GF_SECURITY_ALLOW_EMBEDDING: "true"
      
      # Auth
      GF_AUTH_ANONYMOUS_ENABLED: true
      GF_AUTH_ANONYMOUS_ORG_ROLE: Viewer
      
      # Default dashboard
      GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH: /etc/grafana/provisioning/dashboards/taskyhub-overview.json

      # Database configuration with parameterized names
      GF_DATABASE_TYPE: postgres
      GF_DATABASE_HOST: postgres
      GF_DATABASE_NAME: "{{ grafana_db_name }}"
      GF_DATABASE_USER: "{{ grafana_db_user }}"
      GF_DATABASE_PASSWORD: "{{ tasky_db_grafana_password | default(grafana_db_password | default('')) }}"
      GF_DATABASE_SSL_MODE: disable

    ports:
      - "127.0.0.1:{{ grafana_port }}:3000"
    networks:
      - taskyhub_net
    volumes:
      - grafana_data:/var/lib/grafana
      - ./grafana/provisioning:/etc/grafana/provisioning
      - ./grafana/dashboards:/etc/grafana/provisioning/dashboards
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:3000/api/health >/dev/null 2>&1 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5

  api:
    build:
      context: ./api
      dockerfile: Dockerfile
    container_name: "{{ customer_name }}_api"
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ api_host_port }}:4000"
    environment:
      JWT_SECRET: "{{ tasky_app_jwt_secret | default(jwt_secret | default('')) }}"
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: "{{ postgres_db_name }}"
      DB_USER: "{{ postgres_db_user }}"
      DB_PASSWORD: "{{ tasky_db_main_password | default(taskyhub_db_password | default('')) }}"
      TASKY_ADMIN_EMAIL: "{{ tasky_admin_email | default('devops@taskyhub.local') }}"
      TASKY_ADMIN_PASSWORD: "{{ tasky_app_admin_password | default(tasky_admin_password | default('')) }}"
      TASKY_USER_EMAIL: "{{ tasky_user_email | default('developer@taskyhub.local') }}"
      TASKY_USER_PASSWORD: "{{ tasky_app_user_password | default(tasky_user_password | default('')) }}"
      TASKY_SUBSCRIPTION_ID: "{{ subscription_id | default('') }}"
      AE_DB_NAME: "{{ ae_db_name }}"
      AE_DB_USER: "{{ ae_db_user }}"
      AE_DB_PASSWORD: "{{ tasky_db_ae_password | default(ae_db_password | default('')) }}"
      GRAFANA_URL: http://grafana:3000
      AE_INTERNAL_URL: http://ae:5678
      AE_PUBLIC_URL: "{{ ae_public_url }}"
      TASKY_PUBLIC_URL: "{{ ui_base_url }}"
      TASKY_N8N_PATH_PREFIX: "/ae"
      TASKY_N8N_API_KEY: "{{ tasky_n8n_api_key | default('') }}"
      TASKY_N8N_BASIC_AUTH_USER: "{{ tasky_n8n_basic_auth_user | default('') }}"
      TASKY_N8N_BASIC_AUTH_PASSWORD: "{{ tasky_n8n_basic_auth_password | default('') }}"
      TASKY_INTEGRATIONS_ENCRYPTION_KEY_B64: "{{ tasky_integrations_encryption_key_b64 | default('') }}"
      TASKY_SLACK_CLIENT_ID: "{{ tasky_slack_client_id | default('') }}"
      TASKY_SLACK_CLIENT_SECRET: "{{ tasky_slack_client_secret | default('') }}"
      TASKY_SLACK_SCOPES: "{{ tasky_slack_scopes | default('chat:write,channels:read,groups:read,im:read,mpim:read') }}"
      API_ALLOWED_ORIGINS: "{{ api_allowed_origins | join(',') }}"
      AE_LOG_FILE_PATH: /var/log/ae/n8n.log
    volumes:
      - ./api/data:/usr/src/app/data
      - /opt/{{ customer_name }}/ae-logs:/var/log/ae:ro
    networks:
      - taskyhub_net
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test:
        [
          "CMD-SHELL",
          "node -e \"const http=require('http');http.get('http://127.0.0.1:4000/api/health',res=>process.exit(res.statusCode===200?0:1)).on('error',()=>process.exit(1));\"",
        ]
      interval: 10s
      timeout: 5s
      retries: 5

  ui:
    build:
      context: ./ui
      dockerfile: Dockerfile
    container_name: "{{ customer_name }}_ui"
    restart: unless-stopped
    environment:
      API_URL: "/api"
      GRAFANA_URL: "{{ grafana_base_url }}"
    ports:
      - "127.0.0.1:{{ ui_host_port }}:80"
    networks:
      - taskyhub_net
    depends_on:
      api:
        condition: service_started
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:80/ >/dev/null 2>&1 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  pg_data:
    name: "{{ customer_name }}_pg_data"
  ae_data:
    name: "{{ customer_name }}_ae_data"
  grafana_data:
    name: "{{ customer_name }}_grafana_data"

networks:
  taskyhub_net:
    name: "{{ customer_name }}_taskyhub_net"
    driver: bridge
