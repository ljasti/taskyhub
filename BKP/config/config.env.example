# TaskyHub Infrastructure Configuration
# Copy this file, update the values, and rename it to .env
# Then run: ./spinup.sh  (Linux/Mac) or .\spinup.ps1 (Windows)

# ===== AWS Configuration =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-2

# ===== EC2 Configuration =====
KEY_PAIR_NAME=poc
INSTANCE_TYPE=t3.micro

# ===== Customer & Domain Configuration =====
CUSTOMER_NAME=besty
UI_DOMAIN=taskyhub.xyz
UI_PORT=8080
API_DOMAIN=taskyhub.xyz
API_PORT=4000

# ===== SSH Configuration =====
# Linux/Mac: /home/username/.ssh/key.pem
# Windows: C:\Users\Username\.ssh\key.pem
SSH_KEY_PATH=/home/username/.ssh/your-key-pair.pem

# ===== Credentials Notes (Important) =====
# TaskyHub dashboard users and all n8n authentication are configured via:
#   infra/ansible/vault/secrets.yml  (Ansible vault)
#
# Separate concepts:
# - TaskyHub app users (admin/developer): tasky_app_admin_password / tasky_app_user_password (+ emails in infra/ansible/vars.yml)
# - n8n owner/admin (UI setup only, first run): tasky_n8n_owner_* or complete setup via /ae/setup
# - TaskyHub backend → n8n API auth (for creating / updating n8n credentials): tasky_n8n_api_key OR tasky_n8n_basic_auth_*
