server {
    listen 80;
    server_name {{ domain_name }};

    root /home/{{ ansible_user }}/taskyhub/ui;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location /api/ {
        proxy_pass http://localhost:4000/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}