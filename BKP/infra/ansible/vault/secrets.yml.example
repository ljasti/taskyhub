---
# Example secrets file (DO NOT commit real secrets).
#
# Create encrypted file:
#   cd infra/ansible
#   ansible-vault create vault/secrets.yml
# Then paste these keys with your real values.

# PostgreSQL superuser password used by the Postgres container
tasky_db_super_password: "CHANGE_ME_postgres_superuser_password"

# Database user passwords (naming conventions handled elsewhere)
tasky_db_main_password: "CHANGE_ME_taskyhub_db_user_password"
tasky_db_ae_password: "CHANGE_ME_ae_db_user_password"
tasky_db_grafana_password: "CHANGE_ME_grafana_db_user_password"

# App secrets
tasky_app_jwt_secret: "CHANGE_ME_long_random_jwt_secret"

# TaskyHub login bootstrap (set to match your local working credentials)
tasky_app_admin_password: "CHANGE_ME_admin_password"
tasky_app_user_password: "CHANGE_ME_user_password"

# n8n owner/admin (only used on first-run bootstrap; otherwise complete setup via /ae/setup)
tasky_n8n_owner_email: ""
tasky_n8n_owner_password: ""
tasky_n8n_owner_first_name: "Tasky"
tasky_n8n_owner_last_name: "Admin"

# TaskyHub → n8n API authentication for backend-driven credential management
# Preferred: n8n API key (created once in n8n and stored only on backend)
tasky_n8n_api_key: "CHANGE_ME_n8n_api_key"
#
# Optional: n8n Basic Auth (protects /ae UI + API behind an extra auth layer)
tasky_n8n_basic_auth_user: "taskyhub"
tasky_n8n_basic_auth_password: "CHANGE_ME_n8n_basic_auth_password"

# Encryption key for TaskyHub-stored integration secrets (base64 of 32 bytes)
tasky_integrations_encryption_key_b64: "CHANGE_ME_base64_32_bytes"

# Slack OAuth (TaskyHub app credentials; used to connect a user's Slack workspace)
tasky_slack_client_id: ""
tasky_slack_client_secret: ""
tasky_slack_scopes: "chat:write,channels:read,groups:read,im:read,mpim:read"

# Grafana admin
tasky_grafana_admin_user: "admin"
tasky_grafana_admin_password: "CHANGE_ME_grafana_admin_password"

