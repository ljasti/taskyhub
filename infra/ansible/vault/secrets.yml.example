---
# Example secrets file (DO NOT commit real secrets).
#
# Create encrypted file:
#   cd infra/ansible
#   ansible-vault create vault/secrets.yml
# Then paste these keys with your real values.

# PostgreSQL superuser password used by the Postgres container
postgres_password: "CHANGE_ME_postgres_superuser_password"

# Database user passwords (naming conventions handled elsewhere)
postgres_db_password: "CHANGE_ME_taskyhub_db_user_password"
ae_db_password: "CHANGE_ME_ae_db_user_password"
grafana_db_password: "CHANGE_ME_grafana_db_user_password"

# App secrets
jwt_secret: "CHANGE_ME_long_random_jwt_secret"

# TaskyHub login bootstrap (set to match your local working credentials)
tasky_admin_password: "CHANGE_ME_admin_password"
tasky_user_password: "CHANGE_ME_user_password"

# Grafana admin
grafana_admin_user: "admin"
grafana_admin_password: "CHANGE_ME_grafana_admin_password"

# Password hashes stored in TaskyHub DB (bcrypt hashes expected)
# Generate on your workstation:
#   node -e "const bcrypt=require('bcryptjs'); bcrypt.hash('AdminPass123!',10).then(console.log)"
admin_password_hash: "CHANGE_ME_BCRYPT_HASH"
user_password_hash: "CHANGE_ME_BCRYPT_HASH"

