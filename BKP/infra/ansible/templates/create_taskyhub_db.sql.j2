-- templates/create_taskyhub_db.sql.j2
-- TaskyHub role + database bootstrap (idempotent, parameterised).
-- Intended to be executed as a superuser (e.g. postgres) against the postgres DB.

DO $$
BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '{{ tasky_db_main_user }}') THEN
    EXECUTE format(
      'CREATE ROLE %I LOGIN PASSWORD %L',
      '{{ tasky_db_main_user }}',
      '{{ tasky_db_main_password }}'
    );
  ELSE
    EXECUTE format(
      'ALTER ROLE %I WITH LOGIN PASSWORD %L',
      '{{ tasky_db_main_user }}',
      '{{ tasky_db_main_password }}'
    );
  END IF;
END
$$;

SELECT format(
  'CREATE DATABASE %I OWNER %I',
  '{{ tasky_db_main_name }}',
  '{{ tasky_db_main_user }}'
)
WHERE NOT EXISTS (
  SELECT 1 FROM pg_database WHERE datname = '{{ tasky_db_main_name }}'
)
\gexec

\connect {{ tasky_db_main_name }}

CREATE EXTENSION IF NOT EXISTS pgcrypto;

CREATE SCHEMA IF NOT EXISTS public;

ALTER SCHEMA public OWNER TO {{ tasky_db_main_user }};
