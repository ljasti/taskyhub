-- templates/init_taskyhub.sql.j2
-- TaskyHub main application database initialization (multi-tenant, parameterised)
-- Rendered by Ansible (Jinja2) and executed as a superuser (e.g. postgres).
--
-- Data Sources (from Ansible):
-- - postgres_db_name: The target database for the customer
-- - postgres_db_user: The application role to own the schema
-- - taskyhub_db_password: Password for the app role
-- - subscription_id: A valid UUID for the customer's subscription
-- - customer_name: Human-readable name for the customer
-- - admin_password_hash: Bcrypt hash for the default admin user
-- - user_password_hash: Bcrypt hash for the default standard user
--
-- DESIGN NOTES:
-- 1) subscription_id MUST be a valid UUID string (e.g. '11111111-1111-1111-1111-111111111111').
-- 2) The script is fully idempotent and safe to re-run multiple times.
-- 3) Schema and table ownership are set to the application user for security.

-- 1) Create application role/user if it does not exist
DO
$$
BEGIN
   IF NOT EXISTS (
       SELECT FROM pg_roles WHERE rolname = '{{ postgres_db_user }}'
   ) THEN
      EXECUTE format(
          'CREATE ROLE %I LOGIN PASSWORD %L',
          '{{ postgres_db_user }}',
          '{{ taskyhub_db_password }}'
      );
   END IF;
END
$$;

-- 2) Create database if it does not exist (owned by the app user)
DO
$$
BEGIN
   IF NOT EXISTS (
       SELECT FROM pg_database WHERE datname = '{{ postgres_db_name }}'
   ) THEN
      EXECUTE format(
          'CREATE DATABASE %I OWNER %I',
          '{{ postgres_db_name }}',
          '{{ postgres_db_user }}'
      );
   END IF;
END
$$;

-- 3) Connect to the TaskyHub application database for this customer
\connect {{ postgres_db_name }}

-- 4) Ensure public schema exists and is owned by the app user
CREATE SCHEMA IF NOT EXISTS public;

ALTER SCHEMA public OWNER TO {{ postgres_db_user }};

GRANT USAGE ON SCHEMA public TO {{ postgres_db_user }};

-- 5) Global privileges for all existing tables/sequences in public
GRANT SELECT, INSERT, UPDATE, DELETE
ON ALL TABLES IN SCHEMA public
TO {{ postgres_db_user }};

GRANT ALL PRIVILEGES
ON ALL SEQUENCES IN SCHEMA public
TO {{ postgres_db_user }};

-- 6) Default privileges so future objects are also accessible
ALTER DEFAULT PRIVILEGES IN SCHEMA public
GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO {{ postgres_db_user }};

ALTER DEFAULT PRIVILEGES IN SCHEMA public
GRANT ALL PRIVILEGES ON SEQUENCES TO {{ postgres_db_user }};

-- 7) Core tables (idempotent-style)

CREATE TABLE IF NOT EXISTS subscriptions (
    id             UUID PRIMARY KEY,
    name           TEXT NOT NULL,
    seat_limit     INTEGER NOT NULL,
    created_at     TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS users (
    id              UUID PRIMARY KEY,
    subscription_id UUID NOT NULL REFERENCES subscriptions(id),
    email           TEXT NOT NULL UNIQUE,
    password        TEXT NOT NULL,
    name            TEXT NOT NULL,
    role            TEXT NOT NULL,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- 7.1) Migration: Convert TEXT columns to UUID if they exist from a previous version
-- This handles the "operator does not exist: text = uuid" error during re-runs.
DO $$
BEGIN
    -- Handle subscriptions.id
    IF EXISTS (
        SELECT 1 FROM information_schema.columns 
        WHERE table_name = 'subscriptions' AND column_name = 'id' AND data_type = 'text'
    ) THEN
        -- Drop foreign keys temporarily
        ALTER TABLE users DROP CONSTRAINT IF EXISTS users_subscription_id_fkey;
        
        -- Update invalid UUID strings to a temporary valid one or the new one
        -- (This is safe because we're aligning the existing 'mummy' dummy data)
        UPDATE subscriptions SET id = '{{ subscription_id }}' WHERE id !~ '^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$';
        
        -- Convert column type
        ALTER TABLE subscriptions ALTER COLUMN id TYPE UUID USING id::uuid;
    END IF;

    -- Handle users.subscription_id
    IF EXISTS (
        SELECT 1 FROM information_schema.columns 
        WHERE table_name = 'users' AND column_name = 'subscription_id' AND data_type = 'text'
    ) THEN
        -- Update invalid UUID strings
        UPDATE users SET subscription_id = '{{ subscription_id }}' WHERE subscription_id !~ '^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$';
        
        -- Convert column type
        ALTER TABLE users ALTER COLUMN subscription_id TYPE UUID USING subscription_id::uuid;
        
        -- Restore foreign key
        IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'users_subscription_id_fkey') THEN
            ALTER TABLE users ADD CONSTRAINT users_subscription_id_fkey FOREIGN KEY (subscription_id) REFERENCES subscriptions(id);
        END IF;
    END IF;
END $$;

-- Re‑apply privileges after table creation/migration to be safe
GRANT SELECT, INSERT, UPDATE, DELETE
ON ALL TABLES IN SCHEMA public
TO {{ postgres_db_user }};

GRANT ALL PRIVILEGES
ON ALL SEQUENCES IN SCHEMA public
TO {{ postgres_db_user }};

-- 8) Seed default subscription for this customer
DO
$$
DECLARE
    sub_id UUID := '{{ subscription_id }}'::uuid;
BEGIN
    IF NOT EXISTS (SELECT 1 FROM subscriptions WHERE id = sub_id) THEN
        INSERT INTO subscriptions (id, name, seat_limit)
        VALUES (
            sub_id,
            '{{ customer_name | default("TaskyHub") | capitalize }} Subscription',
            10
        );
    END IF;
END
$$;

-- 9) Seed default admin and user accounts
DO
$$
DECLARE
    sub_id      UUID := '{{ subscription_id }}'::uuid;
    admin_email TEXT := 'admin@taskyhub.local';
    user_email  TEXT := 'user@taskyhub.local';
BEGIN
    -- Default admin
    IF NOT EXISTS (SELECT 1 FROM users WHERE lower(email) = lower(admin_email)) THEN
        INSERT INTO users (id, subscription_id, email, password, name, role)
        VALUES (
            gen_random_uuid(),
            sub_id,
            admin_email,
            '{{ admin_password_hash }}',
            'Default Admin',
            'admin'
        );
    END IF;

    -- Default normal user
    IF NOT EXISTS (SELECT 1 FROM users WHERE lower(email) = lower(user_email)) THEN
        INSERT INTO users (id, subscription_id, email, password, name, role)
        VALUES (
            gen_random_uuid(),
            sub_id,
            user_email,
            '{{ user_password_hash }}',
            'Default User',
            'user'
        );
    END IF;
END
$$;
