version: "3.9"

services:
  postgres:
    image: postgres:15
    container_name: {{ customer_name }}_postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: {{ postgres_password }}
    volumes:
      - pg_data:/var/lib/postgresql/data
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql
    networks:
      - taskyhub-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5

  n8n:
    image: docker.n8n.io/n8nio/n8n
    container_name: {{ customer_name }}_n8n
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: n8n_db
      DB_POSTGRESDB_USER: n8n_user
      DB_POSTGRESDB_PASSWORD: {{ n8n_db_password }}
      N8N_HOST: {{ domain_name }}
      N8N_PORT: 5678
      N8N_PROTOCOL: https
    volumes:
      - n8n_data:/home/node/.n8n
    networks:
      - taskyhub-net
    ports:
      - "127.0.0.1:5678:5678"

  grafana:
    image: grafana/grafana:latest
    container_name: {{ customer_name }}_grafana
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      GF_SECURITY_ADMIN_USER: {{ grafana_admin_user }}
      GF_SECURITY_ADMIN_PASSWORD: {{ grafana_admin_password }}

      GF_BRANDING_APP_TITLE: TaskyHub
      GF_BRANDING_LOGIN_TITLE: TaskyHub Login

      GF_SECURITY_ALLOW_EMBEDDING: "true"
      
      GF_AUTH_ANONYMOUS_ENABLED: true
      GF_AUTH_ANONYMOUS_ORG_ROLE: Viewer
      
      GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH: /etc/grafana/provisioning/dashboards/taskyhub-overview.json

      GF_DATABASE_TYPE: postgres
      GF_DATABASE_HOST: postgres
      GF_DATABASE_NAME: grafana_db
      GF_DATABASE_USER: grafana_user
      GF_DATABASE_PASSWORD: {{ grafana_db_password }}
      GF_DATABASE_SSL_MODE: disable
    ports:
      - "127.0.0.1:3000:3000"
    networks:
      - taskyhub-net
    volumes:
      - grafana_data:/var/lib/grafana
      - ./grafana/provisioning:/etc/grafana/provisioning
      - ./grafana/dashboards:/etc/grafana/provisioning/dashboards

  api:
    build:
      context: ./api
      dockerfile: Dockerfile
    container_name: {{ customer_name }}_api
    restart: unless-stopped
    ports:
      - "127.0.0.1:4000:4000"
    environment:
      JWT_SECRET: {{ jwt_secret }}
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: taskyhub_db
      DB_USER: taskyhub_user
      DB_PASSWORD: {{ taskyhub_db_password }}
      GRAFANA_URL: http://localhost:3000
      N8N_URL: http://localhost:5678
    volumes:
      - ./api/data:/usr/src/app/data
    networks:
      - taskyhub-net
    depends_on:
      postgres:
        condition: service_healthy

  ui:
    build:
      context: ./ui
      dockerfile: Dockerfile
    container_name: {{ customer_name }}_ui
    restart: unless-stopped
    environment:
      API_URL: http://localhost:4000/api
    ports:
      - "127.0.0.1:8080:80"
    networks:
      - taskyhub-net
    depends_on:
      - api

volumes:
  pg_data:
  n8n_data:
  grafana_data:

networks:
  taskyhub-net:
    driver: bridge
